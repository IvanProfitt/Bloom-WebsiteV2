---
import MarjonyWorking from '../assets/MarjonyWorking.png';
import IvanWorking from '../assets/IvanWorking.png';
import Graphic from '../assets/graphic.png';
---



<section id="sbs-2135">
    <div class="cs-container">
        <div class="cs-image-group">
            <!--Main Image-->
            <picture class="cs-picture cs-picture1">
    <source media="(max-width: 600px)" srcset={MarjonyWorking.src}>
    <source media="(min-width: 601px)" srcset={MarjonyWorking.src}>
         <img loading="lazy" decoding="async" src={MarjonyWorking.src} alt="Ivan Working" width="397" height="304">
</picture>
            <!--Small Image-->
            <picture class="cs-picture cs-picture2">
    <source media="(max-width: 600px)" srcset={IvanWorking.src}>
    <source media="(min-width: 601px)" srcset={IvanWorking.src}>
         <img loading="lazy" decoding="async" src={IvanWorking.src} alt="Marjony Working" width="397" height="304">
</picture>
            <!--Green Graphic-->
            <picture class="cs-graphic">
    <img 
        loading="lazy" 
        decoding="async" 
        src={Graphic.src} 
        alt="graphic" 
        width="630" 
        height="715" 
        aria-hidden="true"
    >
</picture>
        </div>
        <div class="cs-content">
            <span class="cs-topper">Our Philosophy</span>
            <h2 class="cs-title"></h2>
            <h3 class="cs-header">Great Coffee</h3>
            <p class="cs-text">
                Our drinks are the core of what we do - from our elevated classics to our original creations, you can expect distinct flavors and a unique journey in every cup. 
            </p>
            <h3 class="cs-header">Community</h3>
            <p class="cs-text">
                We support the people that supports us. We aim to be a welcoming environment for everyone and allow for a space to be seen and heard. As lifelong New Albanians, we love the city and want to aid in its success.
                
            <h3 class="cs-header">Experience</h3>
            <p class="cs-text">
                Coffee tells a story. From a terroir-focused pourover menu, to an ever-changing special drink menu, we aim to provide every customer with the best possible experience from the moment you enter.
            </p>
        </div>
    </div>
    <!--Floating Flower-->
    
</section>
<style>
/* Mobile - 360px */
/* Mobile - 360px */
@media only screen and (min-width: 0rem) {
  #sbs-2135 {
    padding: var(--sectionPadding);
    /* Allow graphic to bleed out */
    overflow: visible; 
    position: relative;
    z-index: 1;
  }
  #sbs-2135 .cs-container {
    width: 100%;
    max-width: 44rem;
    margin: auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: clamp(3rem, 6vw, 4rem);
  }
  #sbs-2135 .cs-content {
    text-align: left;
    width: 100%;
    max-width: 36.625rem;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }
  #sbs-2135 .cs-header {
    font-size: 1.25rem;
    font-weight: 700;
    line-height: 1.2em;
    margin: 0 0 0.5rem 0;
    color: var(--headerColor);
  }
  #sbs-2135 .cs-text {
    margin-bottom: 1rem;
  }
  #sbs-2135 .cs-image-group {
    overflow: visible;
    font-size: min(2.3vw, .75em);
    width: 39.375em;
    height: 44.6875em;
    position: relative;
    flex: none;
  }
  #sbs-2135 .cs-picture {
    overflow: hidden;
    border: 4px solid #fff;
    display: block;
    position: absolute;
  }
  #sbs-2135 .cs-picture img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    position: absolute;
    top: 0;
    left: 0;
  }
  #sbs-2135 .cs-picture1 {
    width: 25.8125em;
    height: 20em;
    top: 1.625em;
    left: 0;
  }
  #sbs-2135 .cs-picture2 {
    width: 25.8125em;
    height: 29.75em;
    right: 0;
    bottom: 5.1875em;
  }

  /* --- Original Mobile Graphic Positioning --- */
  #sbs-2135 .cs-graphic {
    width: 39.375em;
    height: auto;
    display: block;
    position: absolute;
    top: 0;
    right: 0;
    z-index: -1;
  }
  #sbs-2135 .cs-graphic img {
    width: 100%;
    height: auto;
    display: block;
  }

  #sbs-2135 .cs-flower {
    width: clamp(8.8125rem, 20vw, 13.5rem);
    height: auto;
    display: block;
    position: absolute;
    top: 0;
    right: 0;
    transform: rotateX(180deg);
  }
}

/* Tablet - 768px */
@media only screen and (min-width: 48rem) {
  #sbs-2135 .cs-container {
    max-width: 80rem;
    flex-direction: row;
    justify-content: space-between;
    align-items: stretch;
  }
  #sbs-2135 .cs-content {
    padding: 3rem 0;
    align-self: center;
  }
  #sbs-2135 .cs-image-group {
    font-size: min(1.15vw, 1rem);
    height: auto;
    min-height: 44.6875em;
  }
  #sbs-2135 .cs-picture1 {
    height: 44.7552%;
  }
  #sbs-2135 .cs-picture2 {
    height: 66.573426%;
  }

  #sbs-2135 .cs-graphic {
    top: -4em;    
    right: -2em;  
    width: 43em;  
    height: auto;
    max-width: none;
    position: absolute;
    z-index: -1;
    display: block; 
  }
  #sbs-2135 .cs-graphic img {
    width: 200%;
    height: auto;
  }
}

/* Large Desktop - 1300px */
@media only screen and (min-width: 81.25rem) {
  #sbs-2135 .cs-picture {
    border: 8px solid #fff;
  }
  #sbs-2135 .cs-flower {
    width: 19.3125rem;
    top: auto;
    right: 0;
    bottom: 0;
    transform: none;
  }
}
</style>